{
    "name": "lashing-book-monorepo",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "apps/*"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev -w @lasher-book/api\" \"npm run dev -w @lasher-book/web\"",
        "build": "npm run build --workspaces",
        "install:all": "npm install"
    },
    "devDependencies": {
        "concurrently": "^9.2.1"
    },
    "engines": {
        "node": ">=20"
    }
}